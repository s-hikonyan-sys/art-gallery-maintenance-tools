# Secrets API サービス設定（ローカル開発用テンプレート）
# このファイルをコピーして config.yaml を作成し、make gen-secrets で secret_key と
# secrets.yaml.encrypted を生成してください
#
#   cp config.yaml.example config.yaml
#   make gen-secrets  （リポジトリルートから実行）

server:
  port: 5000
  flask_env: development
  debug: true

# 暗号化ファイルの復号に使用するキー
# make gen-secrets を実行すると自動的にこのファイルの secret_key が更新される
secret_key: "（make gen-secrets を実行して設定）"

# データベース設定（非機密情報。パスワードは secrets.yaml.encrypted から読み込まれる）
database:
  host: art-gallery-db-dev
  port: 5432
  name: art_gallery_dev
  user: artuser
