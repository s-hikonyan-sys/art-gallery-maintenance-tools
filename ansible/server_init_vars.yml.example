---
# server_init_vars.yml のサンプルファイル
# このファイルをコピーして server_init_vars.yml を作成し、値を設定してください。
#
# cp server_init_vars.yml.example server_init_vars.yml
# (server_init_vars.yml は .gitignore 対象)

# ============================================================
# ローカル実行時の事前設定（必須）
# - このファイルの値は Playbook 実行「前」に手元で設定する
# - 特に init_ssh_key / admin_ssh_public_key の不一致はロックアウトの原因になる
# ============================================================

# ============================================================
# VPS 接続情報
# ============================================================

# VPS の IP アドレスまたは FQDN (さくらのVPS コントロールパネルで確認)
# さくらのVPS コントロールパネル「基本情報」に表示されるグローバル IPv4（実値に置き換える）
init_host: "YOUR_VPS_GLOBAL_IP"

# 初回接続に使うローカルの SSH 秘密鍵パス (AlmaLinux 標準ユーザー alma 用)
init_ssh_key: "~/.ssh/sakura_init_key"

# ssh-admin に登録する公開鍵の1行（多くの場合 Phase 0-3 で alma に送った鍵と同じ = sakura_init_key.pub の中身）
# GitHub Actions の server_init ワークフローでは INIT_SSH_PRIVATE_KEY から自動算出して注入する
admin_ssh_public_key: "ssh-ed25519 AAAAC3Nza... from-sakura_init_key.pub"

# ============================================================
# デプロイ SSH 鍵 (GitHub Actions が接続する artgallery ユーザー用)
# PROD_SSH_PRIVATE_KEY に対応する公開鍵の中身を貼り付け
# ============================================================
deploy_ssh_public_key: "ssh-ed25519 AAAAC3Nza... your-deploy-key-public-part"

# ============================================================
# SSL 証明書 (Let's Encrypt)
# ============================================================
certbot_email: "your-email@example.com"

# ============================================================
# GHCR 認証 (Docker イメージ pull 用)
# GitHub の Personal Access Token (read:packages スコープ)
# ============================================================
ghcr_token: "ghp_xxxxxxxxxxxxxxxxxxxx"
ghcr_username: "s-hikonyan-sys"

# ============================================================
# 任意: Fail2ban / ジオブロックの上書き
# （省略時は ansible/group_vars/all.yml のデフォルトを使用）
# ============================================================
# 注意:
# - 以下の項目は「この vars で設定するもの」ではなく、Playbook 実行後にサーバー側へ作成/反映される結果:
#   - ssh-admin ユーザー作成 + admin_ssh_public_key 登録
#   - artgallery ユーザー作成 + deploy_ssh_public_key 登録
#   - AllowUsers ssh-admin 適用（alma の SSH ログイン禁止）
# 自宅など固定グローバルIPを登録すると、Fail2ban による誤BANを避けやすい
# fail2ban_ignore_ips:
#   - "203.0.113.50/32"
#
# ジオブロックを無効化する場合（トラブルシュート用）
# firewall_geo_block_enabled: false
#
# ブロック対象国コード（ISO 3166-1 alpha-2 小文字）を変更する場合
# firewall_blocked_country_codes:
#   - cn
#   - ru
